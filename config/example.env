# Comma-separated list of sources: linkedin, indeed, wellfound, custom_api
JOB_SOURCES=linkedin,indeed,wellfound,custom_api

# Custom API/RSS URLs (comma-separated)
CUSTOM_API_URLS=

# Keyword filters (comma-separated)
KEYWORDS=python,backend,full stack,developer

# Location filters
LOCATION_AUCKLAND=auckland
LOCATION_NZ=new zealand

# Paths to your documents
RESUME_PATH=./docs/resume.pdf
COVER_LETTER_PATH=./docs/cover_letter.pdf

# SQLite DB path
DB_PATH=./data/jobs.db

# Output directory
OUTPUT_DIR=./output
